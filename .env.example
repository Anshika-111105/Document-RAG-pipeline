# Environment Configuration
# Copy this to .env and fill in your own values

# API
API_TITLE=Document RAG Pipeline
API_VERSION=0.1.0
DEBUG=false

# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Embedding Configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Vector Store
VECTOR_STORE_TYPE=faiss
VECTOR_DB_PATH=./vector_db

# Document Processing
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Paths
RAW_DOCUMENTS_PATH=./data/raw_documents
PROCESSED_CHUNKS_PATH=./data/processed_chunks

# Database
POSTGRES_URL=postgresql://user:password@localhost:5432/rag_db
REDIS_URL=redis://localhost:6379
